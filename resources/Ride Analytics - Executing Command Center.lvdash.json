{
  "datasets": [
    {
      "name": "5c64b0f5",
      "displayName": "Live KPIs",
      "queryLines": [
        "SELECT\r\n",
        "  total_revenue_inr,\r\n",
        "  cancellation_rate_pct,\r\n",
        "  active_drivers,\r\n",
        "  avg_fare_inr,\r\n",
        "  CAST(ROUND(total_rides * (100 - cancellation_rate_pct) / 100, 0) AS BIGINT) AS completed_rides\r\n",
        "FROM\r\n",
        "  workspace.realtime.gold_live_kpis"
      ],
      "catalog": "workspace",
      "schema": "realtime"
    },
    {
      "name": "d3267fd5",
      "displayName": "Revenue per Minute",
      "queryLines": [
        "SELECT\r\n",
        "  minute_bucket,\r\n",
        "  revenue_inr,\r\n",
        "  completed_rides\r\n",
        "FROM\r\n",
        "  workspace.realtime.gold_revenue_per_minute\r\n",
        "ORDER BY\r\n",
        "  minute_bucket"
      ],
      "catalog": "workspace",
      "schema": "realtime"
    },
    {
      "name": "aaf11481",
      "displayName": "Ride Status Mix",
      "queryLines": [
        "SELECT\r\n",
        "  status,\r\n",
        "  CAST(ride_count AS BIGINT) AS ride_count\r\n",
        "FROM\r\n",
        "  workspace.realtime.gold_ride_status_breakdown\r\n",
        "ORDER BY\r\n",
        "  ride_count DESC"
      ],
      "catalog": "workspace",
      "schema": "realtime"
    },
    {
      "name": "483d4bb3",
      "displayName": "City Performance",
      "queryLines": [
        "SELECT\r\n",
        "  city,\r\n",
        "  ROUND(revenue_inr, 0) AS revenue_inr\r\n",
        "FROM\r\n",
        "  workspace.realtime.gold_rides_by_city\r\n",
        "ORDER BY\r\n",
        "  revenue_inr DESC"
      ],
      "catalog": "workspace",
      "schema": "realtime"
    },
    {
      "name": "8b4e8ab8",
      "displayName": "Top Revenue Zones",
      "queryLines": [
        "SELECT\r\n",
        "  zone_id,\r\n",
        "  city,\r\n",
        "  ROUND(total_revenue_inr, 0) AS total_revenue_inr,\r\n",
        "  CAST(completed_rides AS BIGINT) AS completed_rides,\r\n",
        "  ROUND(avg_fare_inr, 0) AS avg_fare_inr\r\n",
        "FROM\r\n",
        "  workspace.realtime.gold_top_zones\r\n",
        "ORDER BY\r\n",
        "  total_revenue_inr DESC\r\n",
        "LIMIT 10"
      ],
      "catalog": "workspace",
      "schema": "realtime"
    },
    {
      "name": "81e11900",
      "displayName": "Cancellation Reasons",
      "queryLines": [
        "SELECT\r\n",
        "  city,\r\n",
        "  COALESCE(NULLIF(cancellation_reason, ''), status) AS reason,\r\n",
        "  CAST(SUM(cancellation_count) AS BIGINT) AS cancellation_count\r\n",
        "FROM\r\n",
        "  workspace.realtime.gold_cancellation_analysis\r\n",
        "GROUP BY\r\n",
        "  city,\r\n",
        "  COALESCE(NULLIF(cancellation_reason, ''), status)\r\n",
        "ORDER BY\r\n",
        "  cancellation_count DESC"
      ],
      "catalog": "workspace",
      "schema": "realtime"
    },
    {
      "name": "cb5ec89c",
      "displayName": "Pickup Demand",
      "queryLines": [
        "SELECT\r\n",
        "  city,\r\n",
        "  pickup_area,\r\n",
        "  zone_id,\r\n",
        "  CAST(SUM(total_rides) AS BIGINT) AS total_rides,\r\n",
        "  CAST(SUM(cancelled_rides) AS BIGINT) AS cancelled_rides,\r\n",
        "  ROUND(SUM(cancelled_rides) * 100.0 / NULLIF(SUM(total_rides), 0), 1) AS cancel_rate_pct\r\n",
        "FROM\r\n",
        "  workspace.realtime.gold_pickup_demand\r\n",
        "GROUP BY\r\n",
        "  city,\r\n",
        "  pickup_area,\r\n",
        "  zone_id\r\n",
        "ORDER BY\r\n",
        "  total_rides DESC"
      ],
      "catalog": "workspace",
      "schema": "realtime"
    }
  ],
